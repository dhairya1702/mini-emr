SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_BACKEND=supabase
# For GCP/Cloud SQL cutover, set DATABASE_BACKEND=postgres and fill this.
DATABASE_URL=postgresql://clinic_user:clinic_password@127.0.0.1:5432/clinic_db
STORAGE_BACKEND=supabase
# For GCS cutover, set STORAGE_BACKEND=gcs and fill this.
GCS_PATIENT_ATTACHMENTS_BUCKET=your-gcs-patient-attachments-bucket
AUTH_SECRET=replace-with-a-long-random-secret
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514
APP_ORIGIN=http://127.0.0.1:3000
APP_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SUPER_ADMIN_IDENTIFIERS=
FOLLOW_UP_REMINDER_RUNNER_ENABLED=false
FOLLOW_UP_REMINDER_INTERVAL_SECONDS=300
